#
# Scenario matrix definition.
#
# Each entry: DRIVER_DIR  MODE  NEEDS_FC
#
# Adding a new storage driver / transport:
#   1. Create tests/e2e/drivers/<name>/ with cinder-backend.conf, topo.yaml,
#      topo-vhost.yaml, verify.sh
#   2. Add entries below
#
# The orchestrator iterates SCENARIOS in order. Each scenario runs in
# isolation: gateway DB wiped, Cinder DB wiped, fresh topology applied.

SCENARIOS=(
  "svc_iscsi  non-vhost  false"
  "svc_iscsi  vhost      false"
  "svc_fc     non-vhost  true"
  "svc_fc     vhost      true"
)
