# Minimal OpenSSH sshd configuration for the Apollo Gateway IBM SVC façade.
# Only user "svc" is permitted; every session runs the ForceCommand dispatcher.

Port 22
AddressFamily any
ListenAddress 0.0.0.0

# Host keys generated by ssh-keygen -A at image build time
HostKey /etc/ssh/ssh_host_rsa_key
HostKey /etc/ssh/ssh_host_ecdsa_key
HostKey /etc/ssh/ssh_host_ed25519_key

# Authentication
PubkeyAuthentication yes
PasswordAuthentication yes
PermitEmptyPasswords no
ChallengeResponseAuthentication no
KbdInteractiveAuthentication no

# Disable root login; restrict to "svc" only
PermitRootLogin no
AllowUsers svc

# PAM handles shadow-file password verification
UsePAM yes

# Logging
SyslogFacility AUTH
LogLevel INFO

# Misc hardening
PrintLastLog no
PrintMotd no
AcceptEnv LANG LC_*

# IBM SVC ForceCommand for the svc user
# Every session — interactive or command — runs only the dispatcher.
# SSH_ORIGINAL_COMMAND is set to whatever the client tried to run;
# the dispatcher rejects empty (interactive) sessions.
Match User svc
    ForceCommand /usr/local/bin/apollo-svc-shell
    PermitTTY no
    AllowTcpForwarding no
    X11Forwarding no
    PermitTunnel no
