#
# ForceCommand dispatcher for the IBM SVC SSH façade.
# sshd runs this script for every session by user "svc".
#
# SSH_ORIGINAL_COMMAND is set by sshd when ForceCommand is in effect:
#   - Interactive login attempt → SSH_ORIGINAL_COMMAND is unset/empty → rejected.
#   - "ssh host svctask mkvdisk ..." → SSH_ORIGINAL_COMMAND="svctask mkvdisk ..."
#
# All logic lives in the Python module; this script is a thin launcher.

exec python3 -m apollo_gateway.compat.ibm_svc.shell
